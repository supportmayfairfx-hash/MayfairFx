{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://investment-backend-9nxb.onrender.com/api/:path*"
    },
    {
      "source": "/photos/:path*",
      "destination": "https://investment-backend-9nxb.onrender.com/photos/:path*"
    },
    {
      "source": "/health",
      "destination": "https://investment-backend-9nxb.onrender.com/health"
    }
  ]
}
