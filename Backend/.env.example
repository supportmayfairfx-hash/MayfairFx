# Copy to ".env" (do not commit .env)
PORT=8787
FREECRYPTOAPI_KEY=your_key_here
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
JWT_SECRET=change_me_in_dev
ADMIN_API_KEY=change_me_for_telegram_bot
AUTH_CODE_AUTO_GENERATE=true
CORS_ORIGINS=https://your-frontend.vercel.app
TRUST_PROXY=1
AUTH_COOKIE_SAMESITE=none
AUTH_COOKIE_SECURE=true

# Bitcart (Deposit Gateway)
BITCART_ENABLED=false
BITCART_API_URL=https://your-bitcart-host/api
BITCART_API_KEY=your_bitcart_api_key
BITCART_STORE_ID=
BITCART_INVOICE_PATH=/invoices
BITCART_AUTH_SCHEME=token
BITCART_WEBHOOK_URL=
BITCART_WEBHOOK_SECRET=
BITCART_REDIRECT_URL=
